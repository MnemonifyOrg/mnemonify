    {
      "page_id": "pg_case1_assessment",
      "title": "Knowledge Check & Reflection",
      "blocks": [
        {
          "block_id": "blk_kc1",
          "type": "knowledge-check",
          "content": {
            "question": "Based on the frozen section findings, what is the most appropriate intraoperative recommendation?",
            "options": [
              {
                "id": "opt_a",
                "text": "No further action; margins are clear",
                "correct": false
              },
              {
                "id": "opt_b",
                "text": "Re-excise the involved margin",
                "correct": true,
                "feedback": {
                  "rich_text": [
                    {
                      "t": "text",
                      "v": "Correct. Tumor at the inked margin means residual disease is presumed to remain in the patient; re-excision is the standard intraoperative response."
                    }
                  ],
                  "image_id": null,
                  "reference_ids": []
                }
              },
              {
                "id": "opt_c",
                "text": "Convert immediately to mastectomy without further sampling",
                "correct": false
              },
              {
                "id": "opt_d",
                "text": "Defer any decision until permanent sections regardless of frozen result",
                "correct": false
              }
            ]
          },
          "triggers": []
        },
        {
          "block_id": "blk_reflection1",
          "type": "reflection",
          "include_in_pdf": true,
          "content": {
            "prompt": {
              "rich_text": [
                {
                  "t": "text",
                  "v": "What would you want to know from the surgeon before finalizing this frozen section report?"
                }
              ]
            },
            "storage_mode": "local"
          },
          "triggers": []
        }
      ]
    }
