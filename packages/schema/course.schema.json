{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mnemonify.org/schema/course.schema.json",
  "title": "Mnemonify Course Document",
  "description": "Schema for a Mnemonify course JSON document. See ARCHITECTURE.md Section 3 for the authoritative document model.",
  "type": "object",
  "required": ["schema_version", "meta", "variables", "assets", "pages"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 1
    },
    "meta": { "$ref": "#/definitions/meta" },
    "variables": {
      "type": "array",
      "items": { "$ref": "#/definitions/variable" }
    },
    "assets": {
      "type": "array",
      "items": { "$ref": "#/definitions/asset" }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/page" }
    }
  },
  "definitions": {
    "meta": {
      "type": "object",
      "required": ["course_id", "title", "theme"],
      "additionalProperties": false,
      "properties": {
        "course_id": {
          "type": "string",
          "pattern": "^crs_[a-zA-Z0-9]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "theme": {
          "type": "object",
          "required": ["accent"],
          "additionalProperties": false,
          "properties": {
            "accent": {
              "type": "string",
              "pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$"
            },
            "font_pair": {
              "type": "string"
            }
          }
        },
        "completion_rule": {
          "enum": ["viewed_all_pages", "passed_final_quiz"]
        },
        "header": { "$ref": "#/definitions/rich_text_field" },
        "footer": { "$ref": "#/definitions/rich_text_field" },
        "page_numbering": {
          "type": "boolean"
        },
        "objectives": {
          "type": "array",
          "items": { "$ref": "#/definitions/objective" }
        },
        "concepts": {
          "type": "array",
          "items": { "$ref": "#/definitions/concept" }
        },
        "nav_mode": {
          "enum": ["linear", "free"],
          "default": "free"
        },
        "page_display": {
          "enum": ["flat", "grouped"],
          "default": "flat"
        },
        "page_groups": {
          "type": "array",
          "items": { "$ref": "#/definitions/page_group" }
        },
        "utility_bar": { "$ref": "#/definitions/utility_bar" },
        "resources": {
          "type": "array",
          "items": { "$ref": "#/definitions/resource" }
        }
      }
    },
    "rich_text_field": {
      "type": "object",
      "required": ["rich_text"],
      "additionalProperties": false,
      "properties": {
        "rich_text": {
          "type": "array",
          "items": { "$ref": "#/definitions/rich_text_segment" }
        }
      }
    },
    "rich_text_segment": {
      "type": "object",
      "required": ["t", "v"],
      "additionalProperties": false,
      "properties": {
        "t": { "type": "string" },
        "v": { "type": "string" },
        "asset_id": { "type": "string" }
      }
    },
    "objective": {
      "type": "object",
      "required": ["objective_id", "text"],
      "additionalProperties": false,
      "properties": {
        "objective_id": { "type": "string" },
        "text": { "type": "string" },
        "standard_code": { "type": "string" }
      }
    },
    "concept": {
      "type": "object",
      "required": ["concept_id", "name"],
      "additionalProperties": false,
      "properties": {
        "concept_id": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "page_group": {
      "type": "object",
      "required": ["group_id", "title", "page_ids"],
      "additionalProperties": false,
      "properties": {
        "group_id": {
          "type": "string",
          "pattern": "^grp_[a-zA-Z0-9_]+$"
        },
        "title": { "type": "string", "minLength": 1 },
        "page_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^pg_[a-zA-Z0-9_]+$" }
        }
      }
    },
    "utility_bar": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contact": {
          "type": "object",
          "required": ["enabled"],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "email": { "type": "string" },
            "subject_prefix": { "type": "string" }
          }
        },
        "resources": {
          "type": "object",
          "required": ["enabled"],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "custom": {
          "type": "array",
          "items": { "$ref": "#/definitions/utility_bar_custom_item" }
        }
      }
    },
    "utility_bar_custom_item": {
      "type": "object",
      "required": ["id", "label", "action", "target"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string", "minLength": 1 },
        "action": { "enum": ["modal", "jump_page"] },
        "target": { "type": "string" }
      }
    },
    "resource": {
      "type": "object",
      "required": ["resource_id", "filename", "file_path", "size_bytes", "uploaded_at"],
      "additionalProperties": false,
      "properties": {
        "resource_id": {
          "type": "string",
          "pattern": "^res_[a-zA-Z0-9_]+$"
        },
        "filename": { "type": "string", "minLength": 1 },
        "file_path": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "uploaded_at": { "type": "string" }
      }
    },
    "variable": {
      "type": "object",
      "required": ["name", "type", "default"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "type": {
          "enum": ["boolean", "number", "text"]
        },
        "default": {}
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "boolean" } } },
          "then": { "properties": { "default": { "type": "boolean" } } }
        },
        {
          "if": { "properties": { "type": { "const": "number" } } },
          "then": { "properties": { "default": { "type": "number" } } }
        },
        {
          "if": { "properties": { "type": { "const": "text" } } },
          "then": { "properties": { "default": { "type": "string" } } }
        }
      ]
    },
    "asset": {
      "type": "object",
      "required": ["asset_id", "kind", "src", "alt"],
      "additionalProperties": false,
      "properties": {
        "asset_id": {
          "type": "string",
          "pattern": "^ast_[a-zA-Z0-9_]+$"
        },
        "kind": {
          "type": "string",
          "enum": ["image", "video", "audio"]
        },
        "src": {
          "type": "string",
          "minLength": 1
        },
        "alt": {
          "type": "string",
          "minLength": 1
        },
        "caption": {
          "type": "string"
        }
      }
    },
    "page": {
      "type": "object",
      "required": ["page_id", "title", "blocks"],
      "additionalProperties": false,
      "properties": {
        "page_id": {
          "type": "string",
          "pattern": "^pg_[a-zA-Z0-9_]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/definitions/block" }
        },
        "triggers": {
          "type": "array",
          "items": { "$ref": "#/definitions/trigger" }
        },
        "continue_gate": {
          "$ref": "#/definitions/condition"
        }
      }
    },
    "block": {
      "type": "object",
      "required": ["block_id", "type", "content"],
      "additionalProperties": false,
      "properties": {
        "block_id": {
          "type": "string",
          "pattern": "^blk_[a-zA-Z0-9_]+$"
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "content": {
          "type": "object"
        },
        "label": {
          "type": "string"
        },
        "visibility": { "$ref": "#/definitions/visibility" },
        "visibility_condition": { "$ref": "#/definitions/condition" },
        "triggers": {
          "type": "array",
          "items": { "$ref": "#/definitions/trigger" }
        },
        "include_in_pdf": {
          "type": "boolean"
        },
        "faculty_notes": { "$ref": "#/definitions/rich_text_field" },
        "objective_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "concept_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "layout": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "split": { "type": "integer", "minimum": 25, "maximum": 75 },
            "split_min": { "type": "integer" },
            "split_max": { "type": "integer" }
          }
        },
        "left": { "$ref": "#/definitions/inner_block" },
        "right": { "$ref": "#/definitions/inner_block" }
      }
    },
    "inner_block": {
      "type": "object",
      "required": ["block_id", "type", "content"],
      "additionalProperties": false,
      "properties": {
        "block_id": {
          "type": "string",
          "pattern": "^blk_[a-zA-Z0-9_]+$"
        },
        "type": {
          "enum": ["text", "heading", "image", "embed"]
        },
        "content": {
          "type": "object"
        },
        "label": {
          "type": "string"
        },
        "visibility": { "$ref": "#/definitions/visibility" },
        "visibility_condition": { "$ref": "#/definitions/condition" },
        "triggers": {
          "type": "array",
          "items": { "$ref": "#/definitions/trigger" }
        },
        "include_in_pdf": {
          "type": "boolean"
        },
        "faculty_notes": { "$ref": "#/definitions/rich_text_field" },
        "objective_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "concept_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "visibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "initial": {
          "enum": ["visible", "hidden"]
        }
      }
    },
    "trigger": {
      "type": "object",
      "required": ["trigger_id", "event", "actions"],
      "additionalProperties": false,
      "properties": {
        "trigger_id": {
          "type": "string",
          "pattern": "^trg_[a-zA-Z0-9_]+$"
        },
        "event": {
          "enum": [
            "onPageEnter",
            "onPageExit",
            "onClick",
            "onOpen",
            "onClose",
            "onComplete",
            "onCorrect",
            "onIncorrect",
            "onVarChange",
            "onTimerEnd"
          ]
        },
        "condition": { "$ref": "#/definitions/condition" },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/action" }
        }
      }
    },
    "comparison": {
      "type": "object",
      "required": ["var", "op", "value"],
      "additionalProperties": false,
      "properties": {
        "var": { "type": "string" },
        "op": { "enum": ["==", "!=", ">", "<", ">=", "<="] },
        "value": {}
      }
    },
    "condition": {
      "oneOf": [
        { "$ref": "#/definitions/comparison" },
        {
          "type": "object",
          "required": ["all"],
          "additionalProperties": false,
          "properties": {
            "all": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/definitions/condition" }
            }
          }
        },
        {
          "type": "object",
          "required": ["any"],
          "additionalProperties": false,
          "properties": {
            "any": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/definitions/condition" }
            }
          }
        }
      ]
    },
    "action": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": {
          "enum": [
            "SET_VAR",
            "ADJUST_VAR",
            "SHOW_BLOCK",
            "HIDE_BLOCK",
            "ENABLE_BLOCK",
            "DISABLE_BLOCK",
            "JUMP_TO_PAGE",
            "OPEN_LIGHTBOX",
            "SET_STATE",
            "SCORM_COMPLETE",
            "SCORM_SET_SCORE"
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "action": { "const": "SET_VAR" } } },
          "then": {
            "required": ["var", "value"],
            "properties": { "var": { "type": "string" }, "value": {} }
          }
        },
        {
          "if": { "properties": { "action": { "const": "ADJUST_VAR" } } },
          "then": {
            "required": ["var", "value"],
            "properties": { "var": { "type": "string" }, "value": { "type": "number" } }
          }
        },
        {
          "if": {
            "properties": {
              "action": { "enum": ["SHOW_BLOCK", "HIDE_BLOCK", "ENABLE_BLOCK", "DISABLE_BLOCK"] }
            }
          },
          "then": {
            "required": ["target"],
            "properties": { "target": { "type": "string" } }
          }
        },
        {
          "if": { "properties": { "action": { "const": "JUMP_TO_PAGE" } } },
          "then": {
            "required": ["target"],
            "properties": { "target": { "type": "string" } }
          }
        },
        {
          "if": { "properties": { "action": { "const": "OPEN_LIGHTBOX" } } },
          "then": {
            "required": ["asset_id"],
            "properties": { "asset_id": { "type": "string" } }
          }
        },
        {
          "if": { "properties": { "action": { "const": "SET_STATE" } } },
          "then": {
            "required": ["target", "state"],
            "properties": { "target": { "type": "string" }, "state": { "type": "string" } }
          }
        },
        {
          "if": { "properties": { "action": { "const": "SCORM_SET_SCORE" } } },
          "then": {
            "required": ["value"],
            "properties": { "value": { "type": "number" } }
          }
        }
      ]
    }
  }
}
