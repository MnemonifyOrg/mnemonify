      "page_id": "pg_case1",
      "title": "Case Discussion",
      "blocks": [
        {
          "block_id": "blk_heading1",
          "type": "heading",
          "content": {
            "text": "Case 1: Breast Margin Frozen Section",
            "level": 1
          },
          "triggers": [],
          "faculty_notes": {
            "rich_text": [
              {
                "t": "text",
                "v": "Ask learners to state the distance to margin in mm before revealing the diagnosis -- this is the detail students most often skip."
              }
            ]
          },
          "objective_ids": [
            "obj_01"
          ],
          "concept_ids": [
            "cpt_01"
          ]
        },
        {
          "block_id": "blk_text1",
          "type": "text",
          "content": {
            "rich_text": [
              {
                "t": "text",
                "v": "A 54-year-old woman undergoes breast-conserving surgery for a 1.8 cm invasive carcinoma. The intraoperative frozen section is submitted to assess the surgical margin closest to the lesion."
              }
            ]
          },
          "triggers": []
        },
        {
          "block_id": "blk_image1",
          "type": "image",
          "content": {
            "asset_id": "ast_slide01",
            "width_preset": "large",
            "alignment": "center"
          },
          "triggers": []
        },
        {
          "block_id": "blk_col1",
          "type": "two_column",
          "content": {},
          "layout": {
            "split": 40,
            "split_min": 25,
            "split_max": 75
          },
          "left": {
            "block_id": "blk_col1_left",
            "type": "text",
            "content": {
              "rich_text": [
                {
                  "t": "text",
                  "v": "The whole slide image to the right shows the frozen section at scanning magnification. Correlate the architecture visible here with the gross description above."
                }
              ]
            },
            "triggers": []
          },
          "right": {
            "block_id": "blk_col1_right",
            "type": "embed",
            "content": {
              "url": "https://www.digitalscope.org",
              "label": "View Whole Slide Image",
              "sandbox": "allow-scripts allow-same-origin allow-popups"
            },
            "triggers": []
          },
          "triggers": []
        },
        {
          "block_id": "blk_tbl1",
          "type": "table",
          "include_in_pdf": true,
          "content": {
            "caption": "CBC results with reference ranges",
            "has_header_row": true,
            "has_header_col": true,
            "rows": [
              [
                "",
                "WBC",
                "RBC",
                "HGB"
              ],
              [
                "Result",
                "5.2 x 10\u00b3",
                "2.7 x 10\u00b3",
                "9.9 g/dL"
              ],
              [
                "Range",
                "4.0-10.0",
                "3.7-5.3",
                "11.7-16.0"
              ]
            ]
          },
          "triggers": []
        }
      ]
    },
    {
      "page_id": "pg_case1_supporting",
      "title": "Supporting Findings",
      "blocks": [
        {
          "block_id": "blk_carousel1",
          "type": "carousel",
          "content": {
            "asset_ids": []
          },
          "triggers": []
        },
        {
          "block_id": "blk_list1",
          "type": "list",
          "content": {
            "style": "bulleted",
            "items": [
              "Review the architectural pattern of the lesion",
              "Assess the distance from tumor to the inked margin",
              "Note any freezing or crush artifact that could obscure interpretation"
            ]
          },
          "triggers": []
        },
        {
          "block_id": "blk_acc1",
          "type": "accordion",
          "content": {
            "items": [
              {
                "title": "Reveal diagnosis",
                "body_blocks": [
                  {
                    "block_id": "blk_acc1_text1",
                    "type": "text",
                    "content": {
                      "rich_text": [
                        {
                          "t": "text",
                          "v": "Invasive ductal carcinoma present at the inked margin. Re-excision of the margin is recommended."
                        }
                      ]
                    },
                    "triggers": []
                  },
                  {
                    "block_id": "blk_acc1_video1",
                    "type": "video",
                    "content": {
                      "asset_id": "ast_video01",
                      "autoplay": false,
                      "loop": false
                    },
                    "triggers": [],
                    "timeline_triggers": [
                      {
                        "trigger_id": "trg_video01_pause_5s",
                        "at_seconds": 5,
                        "actions": [
                          {
                            "action": "OPEN_MODAL",
                            "payload_type": "interactive_video_overlay",
                            "content": {
                              "block": {
                                "block_id": "blk_video01_overlay_kc",
                                "type": "knowledge-check",
                                "content": {
                                  "question": "Which margin action should happen next?",
                                  "options": [
                                    { "id": "opt_overlay_correct", "text": "Re-excise the involved margin", "correct": true },
                                    { "id": "opt_overlay_incorrect", "text": "Take no further action", "correct": false }
                                  ]
                                },
                                "triggers": [
                                  {
                                    "trigger_id": "trg_video01_overlay_correct",
                                    "event": "onCorrect",
                                    "actions": [{ "action": "JUMP_TO_TIMESTAMP", "target": 10 }]
                                  },
                                  {
                                    "trigger_id": "trg_video01_overlay_incorrect",
                                    "event": "onIncorrect",
                                    "actions": [{ "action": "JUMP_TO_TIMESTAMP", "target": 2 }]
                                  }
                                ]
                              }
                            }
                          }
                        ]
                      }
                    ]
                  }
                ],
                "item_id": "itm_smp01"
              }
            ]
          },
          "triggers": [
            {
              "trigger_id": "trg_acc1_open",
              "event": "onOpen",
              "actions": [
                {
                  "action": "SET_VAR",
                  "var": "readDiagnosis",
                  "value": true
                }
              ]
            }
          ]
        },
        {
          "block_id": "blk_tabs1",
          "type": "tabs",
          "content": {
            "items": [
              {
                "label": "Gross Description",
                "body_blocks": [
                  {
                    "block_id": "blk_tabs1_gross_text",
                    "type": "text",
                    "content": {
                      "rich_text": [
                        {
                          "t": "text",
                          "v": "The specimen consists of a firm, irregular mass measuring 1.9 x 1.6 x 1.4 cm, located 0.2 cm from the closest inked margin."
                        }
                      ]
                    },
                    "triggers": []
                  }
                ],
                "item_id": "itm_smp02"
              },
              {
                "label": "Microscopic Description",
                "body_blocks": [
                  {
                    "block_id": "blk_tabs1_micro_text",
                    "type": "text",
                    "content": {
                      "rich_text": [
                        {
                          "t": "text",
                          "v": "Sections show infiltrating nests of atypical glandular epithelium with moderate nuclear pleomorphism extending to the inked margin."
                        }
                      ]
                    },
                    "triggers": []
                  }
                ],
                "item_id": "itm_smp03"
              }
            ]
          },
          "triggers": []
