{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mnemonify.org/schema/course.schema.json",
  "title": "Mnemonify Course Document",
  "description": "Schema for a Mnemonify course JSON document. See ARCHITECTURE.md Section 3 for the authoritative document model.",
  "type": "object",
  "required": ["schema_version", "meta", "variables", "assets", "question_banks", "linked_entities", "pages"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 5
    },
    "meta": { "$ref": "#/definitions/meta" },
    "variables": {
      "type": "array",
      "items": { "$ref": "#/definitions/variable" }
    },
    "assets": {
      "type": "array",
      "items": { "$ref": "#/definitions/asset" }
    },
    "question_banks": {
      "type": "array",
      "items": { "$ref": "#/definitions/question_bank" }
    },
    "linked_entities": {
      "type": "array",
      "items": { "$ref": "#/definitions/linked_entity" }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/page" }
    }
  },
  "definitions": {
    "meta": {
      "type": "object",
      "required": ["course_id", "title", "theme"],
      "additionalProperties": false,
      "properties": {
        "course_id": {
          "type": "string",
          "pattern": "^crs_[a-zA-Z0-9]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "theme": {
          "type": "object",
          "required": ["accent"],
          "additionalProperties": false,
          "properties": {
            "accent": {
              "type": "string",
              "pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$"
            },
            "font_pair": {
              "type": "string"
            }
          }
        },
        "completion_rule": {
          "enum": ["viewed_all_pages", "passed_final_quiz"]
        },
        "publish_settings": { "$ref": "#/definitions/publish_settings" },
        "header": { "$ref": "#/definitions/rich_text_field" },
        "footer": { "$ref": "#/definitions/rich_text_field" },
        "page_numbering": {
          "type": "boolean"
        },
        "objectives": {
          "type": "array",
          "items": { "$ref": "#/definitions/objective" }
        },
        "concepts": {
          "type": "array",
          "items": { "$ref": "#/definitions/concept" }
        },
        "nav_mode": {
          "enum": ["linear", "free"],
          "default": "linear"
        },
        "page_display": {
          "enum": ["flat", "grouped"],
          "default": "flat"
        },
        "page_groups": {
          "type": "array",
          "items": { "$ref": "#/definitions/page_group" }
        },
        "utility_bar": { "$ref": "#/definitions/utility_bar" },
        "resources": {
          "type": "array",
          "items": { "$ref": "#/definitions/resource" }
        },
        "pdf_settings": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "mode": { "enum": ["combined", "per_page", "both"], "default": "both" },
            "resources_page": { "type": "boolean", "default": true }
          }
        }
      }
    },
    "rich_text_field": {
      "type": "object",
      "required": ["rich_text"],
      "additionalProperties": false,
      "properties": {
        "rich_text": {
          "type": "array",
          "items": { "$ref": "#/definitions/rich_text_segment" }
        }
      }
    },
    "publish_settings": {
      "type": "object",
      "required": ["completion_criteria", "report_status_as", "success_enabled", "passing_score_pct"],
      "additionalProperties": false,
      "properties": {
        "completion_criteria": { "enum": ["viewed_all_pages", "passed_assessment", "either"] },
        "report_status_as": { "enum": ["completion_only", "success_only", "both"] },
        "success_enabled": { "type": "boolean" },
        "passing_score_pct": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "rich_text_segment": {
      "type": "object",
      "required": ["t"],
      "additionalProperties": false,
      "properties": {
        "t": { "enum": ["text", "html", "asset_link", "variable"] },
        "v": { "type": "string" },
        "asset_id": { "type": "string" },
        "var_name": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "t": { "const": "variable" } } },
          "then": { "required": ["var_name"] },
          "else": { "required": ["v"] }
        }
      ]
    },
    "question_bank": {
      "type": "object",
      "required": ["bank_id", "questions"],
      "additionalProperties": false,
      "properties": {
        "bank_id": { "type": "string", "pattern": "^bnk_[a-zA-Z0-9_]+$" },
        "name": { "type": "string", "minLength": 1 },
        "questions": {
          "type": "array",
          "items": { "$ref": "#/definitions/question_bank_question" }
        }
      }
    },
    "question_bank_question": {
      "type": "object",
      "required": ["question_id", "scored"],
      "additionalProperties": false,
      "properties": {
        "question_id": { "type": "string", "pattern": "^bq_[a-zA-Z0-9_]+$" },
        "content": { "$ref": "#/definitions/knowledge_check_content" },
        "scored": { "type": "boolean" },
        "objective_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "linked_entity_id": {
          "type": "string",
          "pattern": "^ent_[a-zA-Z0-9_]+$"
        }
      },
      "allOf": [
        {
          "if": { "required": ["linked_entity_id"] },
          "then": { "not": { "required": ["content"] } },
          "else": { "required": ["content"] }
        }
      ]
    },
    "linked_entity": {
      "type": "object",
      "required": ["entity_id", "block_type", "content", "metadata"],
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "type": "string",
          "pattern": "^ent_[a-zA-Z0-9_]+$"
        },
        "block_type": {
          "type": "string",
          "minLength": 1
        },
        "content": { "type": "object" },
        "metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scored", "objective_ids", "tags", "block_fields"],
          "properties": {
            "scored": { "type": "boolean" },
            "objective_ids": { "type": "array", "items": { "type": "string" } },
            "tags": { "type": "array", "items": { "type": "string" } },
            "block_fields": { "type": "object", "additionalProperties": true }
          }
        }
      }
    },
    "knowledge_check_content": {
      "type": "object",
      "required": ["question", "options"],
      "additionalProperties": true,
      "properties": {
        "scored": { "type": "boolean" },
        "multi_select": {
          "type": "boolean",
          "default": false
        },
        "question": { "type": ["string", "array"] },
        "question_image_id": { "type": ["string", "null"] },
        "options": { "type": "array", "minItems": 2, "items": { "type": "object" } },
        "correct_option_id": { "type": "string" },
        "correct_option_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "feedback_mode": {
          "enum": ["summary", "per_option"],
          "default": "summary"
        },
        "correct_feedback": { "type": ["string", "array"] },
        "incorrect_feedback": { "type": ["string", "array"] },
        "show_feedback": { "type": "boolean" }
      }
    },
    "objective": {
      "type": "object",
      "required": ["objective_id"],
      "additionalProperties": false,
      "properties": {
        "objective_id": { "type": "string" },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "text": { "type": "string" },
        "standard_code": { "type": "string" }
      },
      "anyOf": [
        { "required": ["label"] },
        { "required": ["text"] }
      ]
    },
    "concept": {
      "type": "object",
      "required": ["concept_id", "name"],
      "additionalProperties": false,
      "properties": {
        "concept_id": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "page_group": {
      "type": "object",
      "required": ["group_id", "title", "page_ids"],
      "additionalProperties": false,
      "properties": {
        "group_id": {
          "type": "string",
          "pattern": "^grp_[a-zA-Z0-9_]+$"
        },
        "title": { "type": "string", "minLength": 1 },
        "page_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^pg_[a-zA-Z0-9_]+$" }
        },
        "objective_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "utility_bar": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contact": {
          "type": "object",
          "required": ["enabled"],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "email": { "type": "string" },
            "subject_prefix": { "type": "string" }
          }
        },
        "resources": {
          "type": "object",
          "required": ["enabled"],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "custom": {
          "type": "array",
          "items": { "$ref": "#/definitions/utility_bar_custom_item" }
        }
      }
    },
    "utility_bar_custom_item": {
      "type": "object",
      "required": ["id", "label", "action", "target"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string", "minLength": 1 },
        "action": { "enum": ["modal", "jump_page"] },
        "target": { "type": "string" }
      }
    },
    "resource": {
      "type": "object",
      "required": ["resource_id", "filename", "file_path", "size_bytes", "uploaded_at"],
      "additionalProperties": false,
      "properties": {
        "resource_id": {
          "type": "string",
          "pattern": "^res_[a-zA-Z0-9_]+$"
        },
        "filename": { "type": "string", "minLength": 1 },
        "file_path": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "uploaded_at": { "type": "string" }
      }
    },
    "variable": {
      "type": "object",
      "required": ["variable_id", "name", "type", "default"],
      "additionalProperties": false,
      "properties": {
        "variable_id": {
          "type": "string",
          "pattern": "^var_[a-zA-Z0-9_]+$"
        },
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "type": {
          "enum": ["boolean", "number", "text"]
        },
        "default": {}
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "boolean" } } },
          "then": { "properties": { "default": { "type": "boolean" } } }
        },
        {
          "if": { "properties": { "type": { "const": "number" } } },
          "then": { "properties": { "default": { "type": "number" } } }
        },
        {
          "if": { "properties": { "type": { "const": "text" } } },
          "then": { "properties": { "default": { "type": "string" } } }
        }
      ]
    },
    "asset": {
      "type": "object",
      "required": ["asset_id", "kind", "src", "alt"],
      "additionalProperties": false,
      "properties": {
        "asset_id": {
          "type": "string",
          "pattern": "^ast_[a-zA-Z0-9_]+$"
        },
        "kind": {
          "type": "string",
          "enum": ["image", "video", "audio"]
        },
        "src": {
          "type": "string",
          "minLength": 1
        },
        "alt": {
          "type": "string"
        },
        "caption": {
          "type": "string"
        },
        "caption_status": {
          "type": "string",
          "enum": ["generating", "ready", "failed"]
        },
        "caption_review_status": {
          "type": "string",
          "enum": ["draft", "reviewed"]
        },
        "transcript_status": {
          "type": "string",
          "enum": ["generating", "ready", "failed"]
        }
      }
    },
    "page": {
      "type": "object",
      "required": ["page_id", "title", "blocks"],
      "additionalProperties": false,
      "properties": {
        "page_id": {
          "type": "string",
          "pattern": "^pg_[a-zA-Z0-9_]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/definitions/block" }
        },
        "triggers": {
          "type": "array",
          "items": { "$ref": "#/definitions/trigger" }
        },
        "continue_gate": {
          "$ref": "#/definitions/condition"
        }
      }
    },
    "block": {
      "type": "object",
      "required": ["block_id", "type"],
      "additionalProperties": false,
      "properties": {
        "block_id": {
          "type": "string",
          "pattern": "^blk_[a-zA-Z0-9_]+$"
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "linked_entity_id": {
          "type": "string",
          "pattern": "^ent_[a-zA-Z0-9_]+$"
        },
        "content": {
          "type": "object"
        },
        "label": {
          "type": "string"
        },
        "visibility": { "$ref": "#/definitions/visibility" },
        "visibility_condition": { "$ref": "#/definitions/condition" },
        "triggers": {
          "type": "array",
          "items": { "$ref": "#/definitions/trigger" }
        },
        "timeline_triggers": {
          "type": "array",
          "items": { "$ref": "#/definitions/timeline_trigger" }
        },
        "include_in_pdf": {
          "type": "boolean"
        },
        "faculty_notes": { "$ref": "#/definitions/rich_text_field" },
        "objective_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "concept_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "layout": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "split": { "type": "integer", "minimum": 25, "maximum": 75 },
            "split_min": { "type": "integer" },
            "split_max": { "type": "integer" }
          }
        },
        "left": { "$ref": "#/definitions/inner_block" },
        "right": { "$ref": "#/definitions/inner_block" }
      },
      "allOf": [
        {
          "if": { "required": ["linked_entity_id"] },
          "then": { "not": { "required": ["content"] } },
          "else": { "required": ["content"] }
        },
        {
          "if": { "properties": { "type": { "const": "accordion" } } },
          "then": { "properties": { "content": { "$ref": "#/definitions/items_with_stable_ids" } } }
        },
        {
          "if": { "properties": { "type": { "const": "tabs" } } },
          "then": { "properties": { "content": { "$ref": "#/definitions/items_with_stable_ids" } } }
        },
        {
          "if": {
            "properties": {
              "type": { "enum": ["knowledge-check", "matching", "ordering"] }
            }
          },
          "then": {
            "properties": {
              "content": {
                "type": "object",
                "properties": { "scored": { "type": "boolean" } }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": { "const": "hotspot" }
            }
          },
          "then": {
            "properties": {
              "content": {
                "type": "object",
                "properties": { "scored": { "type": "boolean" } }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": { "const": "question_bank_draw" }
            }
          },
          "then": {
            "properties": {
              "content": {
                "type": "object",
                "required": ["bank_id", "draw_count"],
                "additionalProperties": false,
                "properties": {
                  "bank_id": { "type": "string", "pattern": "^bnk_[a-zA-Z0-9_]+$" },
                  "draw_count": { "type": "integer", "minimum": 1 },
                  "objective_fallback": { "enum": ["draw_fewer", "include_unmapped"] }
                }
              }
            }
          }
        }
      ]
    },
    "items_with_stable_ids": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["item_id"],
            "properties": {
              "item_id": {
                "type": "string",
                "pattern": "^itm_[a-zA-Z0-9_]+$"
              }
            }
          }
        }
      }
    },
    "inner_block": {
      "type": "object",
      "required": ["block_id", "type", "content"],
      "additionalProperties": false,
      "properties": {
        "block_id": {
          "type": "string",
          "pattern": "^blk_[a-zA-Z0-9_]+$"
        },
        "type": {
          "enum": ["text", "heading", "image", "embed"]
        },
        "content": {
          "type": "object"
        },
        "label": {
          "type": "string"
        },
        "visibility": { "$ref": "#/definitions/visibility" },
        "visibility_condition": { "$ref": "#/definitions/condition" },
        "triggers": {
          "type": "array",
          "items": { "$ref": "#/definitions/trigger" }
        },
        "include_in_pdf": {
          "type": "boolean"
        },
        "faculty_notes": { "$ref": "#/definitions/rich_text_field" },
        "objective_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "concept_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "visibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "initial": {
          "enum": ["visible", "hidden"]
        }
      }
    },
    "trigger": {
      "type": "object",
      "required": ["trigger_id", "event", "actions"],
      "additionalProperties": false,
      "properties": {
        "trigger_id": {
          "type": "string",
          "pattern": "^trg_[a-zA-Z0-9_]+$"
        },
        "event": {
          "enum": [
            "onPageEnter",
            "onPageExit",
            "onClick",
            "onOpen",
            "onClose",
            "onComplete",
            "onCorrect",
            "onIncorrect",
            "onVarChange",
            "onTimerEnd",
            "onTimeReached"
          ]
        },
        "condition": { "$ref": "#/definitions/condition" },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/action" }
        }
      }
    },
    "timeline_trigger": {
      "type": "object",
      "required": ["trigger_id", "at_seconds", "actions"],
      "additionalProperties": false,
      "properties": {
        "trigger_id": {
          "type": "string",
          "pattern": "^trg_[a-zA-Z0-9_]+$"
        },
        "at_seconds": {
          "type": "number",
          "minimum": 0
        },
        "condition": { "$ref": "#/definitions/condition" },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/action" }
        }
      }
    },
    "comparison": {
      "type": "object",
      "required": ["var", "op", "value"],
      "additionalProperties": false,
      "properties": {
        "var": { "type": "string" },
        "op": { "enum": ["==", "!=", ">", "<", ">=", "<="] },
        "value": {}
      }
    },
    "condition": {
      "oneOf": [
        { "$ref": "#/definitions/comparison" },
        {
          "type": "object",
          "required": ["all"],
          "additionalProperties": false,
          "properties": {
            "all": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/definitions/condition" }
            }
          }
        },
        {
          "type": "object",
          "required": ["any"],
          "additionalProperties": false,
          "properties": {
            "any": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/definitions/condition" }
            }
          }
        }
      ]
    },
    "action": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": {
          "enum": [
            "SET_VAR",
            "ADJUST_VAR",
            "SHOW_BLOCK",
            "HIDE_BLOCK",
            "ENABLE_BLOCK",
            "DISABLE_BLOCK",
            "JUMP_TO_PAGE",
            "JUMP_TO_TIMESTAMP",
            "OPEN_MODAL",
            "OPEN_LIGHTBOX",
            "SET_STATE",
            "SCORM_COMPLETE",
            "SCORM_SET_SCORE"
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "action": { "const": "SET_VAR" } } },
          "then": {
            "required": ["var", "value"],
            "properties": { "var": { "type": "string" }, "value": {} }
          }
        },
        {
          "if": { "properties": { "action": { "const": "ADJUST_VAR" } } },
          "then": {
            "required": ["var", "value"],
            "properties": { "var": { "type": "string" }, "value": { "type": "number" } }
          }
        },
        {
          "if": {
            "properties": {
              "action": { "enum": ["SHOW_BLOCK", "HIDE_BLOCK", "ENABLE_BLOCK", "DISABLE_BLOCK"] }
            }
          },
          "then": {
            "required": ["target"],
            "properties": { "target": { "type": "string" } }
          }
        },
        {
          "if": { "properties": { "action": { "const": "JUMP_TO_PAGE" } } },
          "then": {
            "required": ["target"],
            "properties": { "target": { "type": "string" } }
          }
        },
        {
          "if": { "properties": { "action": { "const": "JUMP_TO_TIMESTAMP" } } },
          "then": {
            "required": ["target"],
            "properties": { "target": { "type": "number", "minimum": 0 } }
          }
        },
        {
          "if": { "properties": { "action": { "const": "OPEN_MODAL" } } },
          "then": {
            "required": ["payload_type", "content"],
            "properties": {
              "payload_type": { "const": "interactive_video_overlay" },
              "content": { "type": "object" }
            }
          }
        },
        {
          "if": { "properties": { "action": { "const": "OPEN_LIGHTBOX" } } },
          "then": {
            "required": ["asset_id"],
            "properties": { "asset_id": { "type": "string" } }
          }
        },
        {
          "if": { "properties": { "action": { "const": "SET_STATE" } } },
          "then": {
            "required": ["target", "state"],
            "properties": { "target": { "type": "string" }, "state": { "type": "string" } }
          }
        },
        {
